<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Universe - Explore the Future</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Inter:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        /* CSS Reset & Variables */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        :root {
            --bg-dark: #0a0a16;
            --primary-glow: #00f2fe;
            --secondary-glow: #4facfe;
            --text-light: #ffffff;
            --text-muted: #8a8da4;
            --card-bg: rgba(255, 255, 255, 0.05);
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-light);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* --- 1. Animated Particle Background --- */
        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: radial-gradient(circle at 50% 50%, #141432, #050510);
            overflow: hidden;
        }
        .bg-animation::before {
            content: '';
            position: absolute;
            width: 200%;
            height: 200%;
            background-image: radial-gradient(rgba(0, 242, 254, 0.15) 1px, transparent 0);
            background-size: 40px 40px;
            top: -50%;
            left: -50%;
            animation: gridMove 20s linear infinite;
        }
        @keyframes gridMove {
            0% { transform: translateY(0); }
            100% { transform: translateY(40px); }
        }

        /* --- 2. Header & Navigation --- */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 5%;
            background: rgba(10, 10, 22, 0.8);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid rgba(0, 242, 254, 0.2);
        }
        .logo {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.5rem;
            font-weight: bold;
            background: linear-gradient(45deg, var(--primary-glow), var(--secondary-glow));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 15px rgba(0, 242, 254, 0.3);
        }
        nav a {
            color: var(--text-light);
            text-decoration: none;
            margin-left: 20px;
            font-weight: 500;
            transition: color 0.3s;
        }
        nav a:hover {
            color: var(--primary-glow);
        }

        /* --- 3. Hero Section & Search Engine --- */
        .hero {
            text-align: center;
            padding: 100px 20px 60px;
            max-width: 800px;
            margin: 0 auto;
        }
        .hero h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 3.5rem;
            margin-bottom: 20px;
            animation: pulseText 3s ease-in-out infinite alternate;
        }
        @keyframes pulseText {
            0% { text-shadow: 0 0 10px rgba(0, 242, 254, 0.5); }
            100% { text-shadow: 0 0 25px rgba(0, 242, 254, 0.8), 0 0 50px rgba(79, 172, 254, 0.4); }
        }
        .hero p {
            color: var(--text-muted);
            font-size: 1.2rem;
            margin-bottom: 40px;
        }

        /* Search Engine Box */
        .search-container {
            position: relative;
            max-width: 600px;
            margin: 0 auto;
            border-radius: 30px;
            background: rgba(255, 255, 255, 0.05);
            padding: 5px;
            border: 1px solid rgba(0, 242, 254, 0.3);
            box-shadow: 0 0 20px rgba(0, 242, 254, 0.1);
            transition: all 0.3s;
        }
        .search-container:focus-within {
            border-color: var(--primary-glow);
            box-shadow: 0 0 25px rgba(0, 242, 254, 0.3);
        }
        .search-box {
            width: 100%;
            padding: 15px 25px;
            background: transparent;
            border: none;
            outline: none;
            color: white;
            font-size: 1.1rem;
        }
        .search-btn {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            background: linear-gradient(45deg, var(--primary-glow), var(--secondary-glow));
            border: none;
            padding: 10px 25px;
            color: black;
            font-weight: bold;
            border-radius: 20px;
            cursor: pointer;
            transition: transform 0.2s;
        }
        .search-btn:hover {
            transform: translateY(-50%) scale(1.05);
        }
        .search-results {
            margin-top: 20px;
            padding: 15px;
            border-radius: 15px;
            background: rgba(10, 10, 22, 0.9);
            border: 1px solid rgba(255, 255, 255, 0.1);
            display: none;
            text-align: left;
        }

        /* --- 4. Main Content (Describing AI) --- */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        .section-title {
            font-family: 'Orbitron', sans-serif;
            text-align: center;
            font-size: 2rem;
            margin-bottom: 40px;
            letter-spacing: 2px;
        }

        /* Media Section (Video & Pictures) */
        .media-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            margin-bottom: 80px;
        }
        .media-card {
            background: var(--card-bg);
            border-radius: 15px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: transform 0.3s;
        }
        .media-card:hover {
            transform: translateY(-10px);
        }
        .media-card img, .media-card video {
            width: 100%;
            height: 220px;
            object-fit: cover;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        .media-info {
            padding: 20px;
        }
        .media-info h3 {
            margin-bottom: 10px;
            font-family: 'Orbitron', sans-serif;
            color: var(--primary-glow);
        }

        /* --- 5. AI Machine Portal --- */
        .ai-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
        }
        .ai-card {
            background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.08));
            border-radius: 20px;
            padding: 30px;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.1);
            position: relative;
            transition: all 0.3s ease;
        }
        .ai-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            border-radius: 20px;
            box-shadow: 0 0 15px rgba(0, 242, 254, 0);
            transition: box-shadow 0.3s;
            pointer-events: none;
        }
        .ai-card:hover {
            border-color: var(--primary-glow);
            transform: translateY(-5px);
        }
        .ai-card:hover::before {
            box-shadow: 0 0 20px rgba(0, 242, 254, 0.2);
        }
        .ai-icon {
            font-size: 3rem;
            margin-bottom: 15px;
        }
        .ai-card h3 {
            font-family: 'Orbitron', sans-serif;
            margin-bottom: 12px;
        }
        .ai-card p {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 20px;
        }
        .launch-btn {
            display: inline-block;
            background: transparent;
            border: 1px solid var(--primary-glow);
            color: var(--primary-glow);
            padding: 8px 20px;
            border-radius: 15px;
            text-decoration: none;
            font-weight: bold;
            transition: all 0.3s;
        }
        .launch-btn:hover {
            background: var(--primary-glow);
            color: black;
            box-shadow: 0 0 15px var(--primary-glow);
        }

        footer {
            text-align: center;
            padding: 40px 20px;
            color: var(--text-muted);
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            margin-top: 60px;
        }
    </style>
</head>
